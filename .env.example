# ─────────────────────────────────────────────────────────────────────────────
# FocusFlow Backend — Environment Variables
#
# Copy this file to backend/.env and fill in your values.
#
#   cp .env.example backend/.env
#
# Never commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── MongoDB ───────────────────────────────────────────────────────────────────

# Option A: Full connection string (recommended for MongoDB Atlas)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Leave blank if using individual host/port variables below.
MONGODB_URL=

# Option B: Individual connection parts (used when MONGODB_URL is not set)
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=focusflow

# MongoDB credentials (optional — only needed if auth is enabled on your instance)
MONGODB_USER=
MONGODB_PASSWORD=

# Auth source database for MongoDB authentication (default: admin)
MONGODB_AUTH_SOURCE=admin

# Connection timeout settings (milliseconds)
# Increase these if you experience connection timeouts on slow networks
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000

# Number of times to retry the initial ping before giving up
MONGODB_PING_RETRIES=5

# Delay in seconds between ping retries
MONGODB_PING_RETRY_DELAY_S=0.5


# ── Authentication ────────────────────────────────────────────────────────────

# Secret key used to sign and verify JWT tokens.
# Use a long random string — minimum 32 characters recommended.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-key

# How long access tokens remain valid (in minutes). Default: 60
JWT_EXPIRE_MINUTES=60


# ── AI Features ──────────────────────────────────────────────────────────────

# OpenAI API key — used if GEMINI_API_KEY is not set on the user's profile.
# Get yours at: https://platform.openai.com/api-keys
# Leave blank to disable server-side OpenAI. Users can add their own Gemini key
# via the Settings page instead.
OPENAI_API_KEY=

# Google Gemini API key — server-side fallback (optional).
# Individual users set their own key via Settings > AI API Key.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
